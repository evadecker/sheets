---
export interface Props {
  title: string;
  pdfUrl: string;
  pngUrls: string[];
  slug?: string;
}

const { title, pdfUrl, pngUrls, slug } = Astro.props;
---

<article class="sheet">
  <header>
    <h2>{title}</h2>
    <a href={pdfUrl} download>Download PDF</a>
    {slug && <a href={`/${slug}`}>Link</a>}
  </header>
  {
    pngUrls.length > 0 && (
      <div class="carousel">
        {pngUrls.map((url: string, i: number) => (
          <img
            src={url}
            alt={`${title} — page ${i + 1}`}
            class="carousel-image"
          />
        ))}
      </div>
    )
  }
</article>

<style>
  .sheet header {
    padding: 2rem;
    padding-bottom: 0;
  }

  .sheet h2 a {
    color: inherit;
    text-decoration: none;

    @media (hover: hover) {
      &:hover {
        text-decoration: underline;
      }
    }
  }

  .carousel {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 2rem;
  }

  .carousel-image {
    flex-shrink: 0;
    width: auto;
    max-height: 60vh;
    object-fit: contain;
  }
</style>
